    {
      "parameters": {
        "operation": "rowNotExists",
        "dataTableId": { "__rl": true, "mode": "name", "value": "seen_jobs" },
        "filters": { "conditions": [{ "keyName": "link", "keyValue": "={{ $json.link }}" }] }
      },
      "id": "6e85cb00-543b-4180-992d-230a6bdb12da",
      "name": "Find New Jobs",
      "type": "n8n-nodes-base.dataTable",
      "typeVersion": 1.1,
      "position": [896, 112]
    },
    {
      "parameters": {
        "promptType": "define",
        "text": "=Вакансия для оценки:\nЗаголовок: {{ $json.title }}\nОписание: {{ $json.content }}\nСсылка: {{ $json.link }}",
        "hasOutputParser": true,
        "options": {
          "systemMessage": "Ты — ассистент по подбору вакансий для AI-автоматизатора. Профиль кандидата: автоматизация на n8n + вайбкодинг (Cursor / Claude Code), интеграции REST API и webhooks, LLM-агенты и RAG (OpenAI, Anthropic), JS/TS и Python. Оцени, насколько вакансия подходит кандидату, и верни строго JSON по заданной схеме. Поле score — целое 0-100. Если score < 50, relevant = false. reason — одно предложение, почему подходит или нет. draft — короткий персональный черновик отклика (3-5 предложений) на языке вакансии, подчёркивающий релевантный опыт кандидата."
        }
      },
      "id": "4f447efe-b905-4501-b585-cc1ff68268ce",
      "name": "Score & Draft Reply",
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 3.1,
      "position": [1120, 112]
    },
    {
      "parameters": {
        "jsonSchemaExample": "{ \"relevant\": true, \"score\": 85, \"reason\": \"Short reason why it fits or not\", \"draft\": \"Short personalised cover letter draft\" }"
      },
      "id": "5032ea7b-9de2-46da-8639-caeb07958951",
      "name": "Job Match Schema",
      "type": "@n8n/n8n-nodes-langchain.outputParserStructured",
      "typeVersion": 1.3,
      "position": [1264, 336]
    },
    {
      "parameters": {
        "assignments": {
          "assignments": [
            { "id": "f1", "name": "relevant", "value": "={{ $json.output.relevant }}", "type": "boolean" },
            { "id": "f2", "name": "score", "value": "={{ $json.output.score }}", "type": "number" },
            { "id": "f3", "name": "link", "value": "={{ $(\"Find New Jobs\").item.json.link }}", "type": "string" },
            { "id": "f4", "name": "message", "value": "=🎯 Score {{ $json.output.score }}/100\n📌 {{ $(\"Find New Jobs\").item.json.title }}\n\n💡 {{ $json.output.reason }}\n\n📝 Черновик отклика:\n{{ $json.output.draft }}\n\n🔗 {{ $(\"Find New Jobs\").item.json.link }}", "type": "string" }
          ]
        },
        "options": {}
      },
      "id": "a8c7a048-365c-420e-bb3e-73e9209e94d0",
      "name": "Format Job",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [1472, 112]
    },
    {
      "parameters": {
        "dataTableId": { "__rl": true, "mode": "name", "value": "seen_jobs" },
        "columns": {
          "mappingMode": "defineBelow",
          "value": { "link": "={{ $(\"Format Job\").item.json.link }}" },
          "schema": [{ "id": "link", "displayName": "link", "required": false, "defaultMatch": false, "display": true, "type": "string", "canBeUsedToMatch": true }]
        },
        "options": {}
      },
      "id": "6737ee64-c605-450c-be4e-8c4ea9a6d815",
