      "typeVersion": 1.1,
      "position": [1696, 112]
    },
    {
      "parameters": {
        "conditions": {
          "options": { "caseSensitive": true, "leftValue": "", "typeValidation": "loose", "version": 1 },
          "combinator": "and",
          "conditions": [{ "leftValue": "={{ $(\"Format Job\").item.json.relevant }}", "operator": { "type": "boolean", "operation": "true", "singleValue": true }, "rightValue": "" }]
